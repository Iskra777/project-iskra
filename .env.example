# Скопіювати в .env і заповнити реальними значеннями. .env у git не потрапляє.

DATABASE_URL="postgresql://user:password@localhost:5432/iskra?schema=public"

# Окремі секрети для access і refresh токенів — компрометація одного не зачіпає інший.
# Згенерувати: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me"
JWT_REFRESH_SECRET="change-me-too"

# Базовий URL застосунку — використовується для посилань у транзакційних листах.
APP_URL="http://localhost:3000"
